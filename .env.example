# SynthIoT Backend — Environment Variables
# ==========================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your actual values below
# 3. Never commit .env to version control!

# ── AI / LLM ──────────────────────────────
# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Serper API key (used by CrewAI web-search tool) — https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ── Database ──────────────────────────────
# Local PostgreSQL (development / local VM)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/synthiot_db

# GCP Cloud SQL — uncomment and fill in for production on GCP
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@/synthiot_db?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# ── Model Artifacts ───────────────────────
MODEL_PATH=AI/timegan_model.pkl
SCALER_PATH=AI/scaler.joblib

# ── Server ────────────────────────────────
# These are picked up by uvicorn when running via systemd.
# deploy.sh passes them automatically; you can override here.
# HOST=0.0.0.0
# PORT=8000
